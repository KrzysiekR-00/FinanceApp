<Page x:Class="FinanceApp.Views.SnapshotEditor"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FinanceApp.Views" 
      xmlns:converters="clr-namespace:FinanceApp.Converters"
      xmlns:viewmodels="clr-namespace:FinanceApp.ViewModels" 
      d:DataContext="{d:DesignInstance Type=viewmodels:SnapshotEditorViewModel}"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SnapshotEditor">

    <Page.Resources>
        <converters:InverseBool x:Key="InverseBool"/>
    </Page.Resources>

    <DockPanel>
        <Label Content="Aktualizuj stan" DockPanel.Dock="Top" FontSize="24" Margin="5"/>
        <Button DockPanel.Dock="Bottom" Content="Zapisz" Command="{Binding SaveCommand}" Margin="5"/>
        <ScrollViewer>
            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal">
                    <Label Content="Data" Margin="5" Width="200"/>
                    <TextBox Text="{Binding Snapshot.Date, 
                        UpdateSourceTrigger=LostFocus,
                        ConverterCulture=pl-PL,
                        StringFormat='{}{0:dd.MM.yyyy}'}" Margin="5" Width="200"/>
                </StackPanel>
                <Label Content="Jednostki" Margin="5"/>
                <ItemsControl ItemsSource="{Binding Snapshot.ExchangeRates}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Label Content="{Binding PortfolioItemUnit.Symbol}" Margin="5" Width="200"/>
                                <TextBox Text="{Binding Value, ConverterCulture=pl-PL}" IsEnabled="{Binding SkipUpdate, Converter={StaticResource InverseBool}}" Margin="5" Width="200"/>
                                <Label Content="{Binding DataContext.MainUnit.Symbol, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Margin="5" Width="100"/>
                                <CheckBox Content="Bez zmian/nie aktualizuj" IsChecked="{Binding SkipUpdate}" Margin="5" Width="200"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Label Content="Aktywa/zobowiązania" Margin="5"/>
                <ItemsControl ItemsSource="{Binding Snapshot.PortfolioItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Label Content="{Binding PortfolioItem.Name}" Margin="5" Width="200"/>
                                <TextBox Text="{Binding Quantity, ConverterCulture=pl-PL}" IsEnabled="{Binding SkipUpdate, Converter={StaticResource InverseBool}}" Margin="5" Width="200"/>
                                <Label Content="{Binding PortfolioItem.Unit.Symbol}" Margin="5" Width="100"/>
                                <CheckBox Content="Bez zmian/nie aktualizuj" IsChecked="{Binding SkipUpdate}" Margin="5" Width="200"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Page>
