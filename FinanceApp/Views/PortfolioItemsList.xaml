<Page x:Class="FinanceApp.Views.PortfolioItemsList"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FinanceApp.Views" xmlns:viewmodels="clr-namespace:FinanceApp.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:PortfolioItemsListViewModel}"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PortfolioItemsList">

    <DockPanel>
        <Label Content="Aktywa/zobowiązania" DockPanel.Dock="Top" FontSize="24" Margin="5"/>
        <DockPanel>
            <StackPanel DockPanel.Dock="Right" MinWidth="250">
                <Label Content="Nazwa:" Margin="5"/>
                <TextBox Margin="5" Text="{Binding EditedItem.Name}"/>
                <Label Content="Jednostka:" Margin="5"/>
                <ComboBox DisplayMemberPath="Symbol" ItemsSource="{Binding PortfolioItemUnits, UpdateSourceTrigger=PropertyChanged}" SelectedItem="{Binding EditedItem.Unit}" Margin="5"/>
                <Label Content="Typ:" Margin="5"/>
                <ComboBox ItemsSource="{Binding PortfolioItemTypes, UpdateSourceTrigger=PropertyChanged}" SelectedItem="{Binding EditedItem.Type}" Margin="5"/>
                <Button Content="Dodaj" Command="{Binding SaveCommand}" Margin="5"/>
            </StackPanel>
            <DataGrid ItemsSource="{Binding PortfolioItems, UpdateSourceTrigger=PropertyChanged}" SelectedItem="{Binding SelectedItem}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" Margin="5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Id" Binding="{Binding PortfolioItem.Id}" IsReadOnly="True" />
                    <DataGridTextColumn Header="Nazwa" Binding="{Binding PortfolioItem.Name}" IsReadOnly="True" />
                    <DataGridTextColumn Header="Jednostka" Binding="{Binding PortfolioItem.Unit.Symbol}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Typ" Binding="{Binding PortfolioItem.Type}" IsReadOnly="True"/>
                    <DataGridTemplateColumn>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Edytuj" Margin="5" IsEnabled="{Binding CanEdit}" Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                    <Button Content="Usuń" Margin="5" IsEnabled="{Binding CanEdit}"  Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </DockPanel>
</Page>
