<Window x:Class="FinanceApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FinanceApp" xmlns:viewmodels="clr-namespace:FinanceApp.ViewModels" 
        d:DataContext="{d:DesignInstance Type=viewmodels:MainWindowViewModel}"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" WindowState="Maximized" Height="450" Width="800">
    <Grid>
        <Frame Content="{Binding StartupViewModel}" NavigationUIVisibility="Hidden" />
    </Grid>
</Window>
